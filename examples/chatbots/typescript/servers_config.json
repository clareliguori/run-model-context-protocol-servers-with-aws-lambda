{
  "stdioServers": {
    "aws-docs": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    }
  },
  "lambdaFunctionServers": {
    "time": {
      "functionName": "mcp-server-time",
      "region": "us-west-2"
    },
    "weatherAlerts": {
      "functionName": "mcp-server-weather-alerts",
      "region": "us-west-2"
    }
  },
  "lambdaFunctionUrls": {
    "mcpdoc": {
      "stackName": "LambdaMcpServer-Mcpdoc"
    },
    "cat-facts": {
      "stackName": "LambdaMcpServer-CatFacts"
    }
  },
  "oAuthServers": {
    "dog-facts": {
      "serverStackName": "LambdaMcpServer-DogFacts"
    },
    "dad-jokes": {
      "serverStackName": "LambdaMcpServer-DadJokes"
    },
    "zen": {
      "serverStackName": "LambdaMcpServer-Zen"
    },
    "bookSearch": {
      "serverStackName": "LambdaMcpServer-BookSearch"
    },
    "dictionary": {
      "serverStackName": "LambdaMcpServer-Dictionary"
    },
    "sns-sqs": {
      "serverStackName": "LambdaMcpServer-SnsSqs"
    }
  }
}
